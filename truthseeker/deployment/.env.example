# ─── TruthSeeker Environment Variables ───

# JWT Secret for Auth sessions. Ensure this is a strong random key in prod.
JWT_SECRET="your-super-strong-jwt-secret-key-here"

# Optional: Path overrides
# MODEL_PATH="./model_output/final_model"
# DB_PATH="./truthseeker.db"

# ─── API Keys ───
# Required for Gemini reasoning; Google Fact Check is disabled by default
GEMINI_API_KEY="your-gemini-api-key"
# GOOGLE_FACT_CHECK_KEY="" # Optional only if you re-enable Google Fact Check

# Note: GDELT is now used for news cross-referencing, which does not require an API key.
